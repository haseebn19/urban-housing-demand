# =============================================================================
# Urban Housing Demand - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Java / Gradle
# -----------------------------------------------------------------------------
*.class
*.jar
*.war
*.ear
build/
!gradle-wrapper.jar
.gradle/
bin/

# -----------------------------------------------------------------------------
# Node.js / React
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# -----------------------------------------------------------------------------
# Environment & Secrets - NEVER COMMIT
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.crt
credentials.json
secrets.json
service-account*.json

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
.idea/
*.iml
*.ipr
*.iws
.vscode/
*.code-workspace
.classpath
.project
.settings/
*.sublime-*

# -----------------------------------------------------------------------------
# OS Generated
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Build & Test Output
# -----------------------------------------------------------------------------
dist/
out/
target/
coverage/
.nyc_output/
*.tsbuildinfo
test-results/
junit.xml

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
*.pid
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.swp
*.swo
*~
*.bak
