# Required: no default for security
DB_PASSWORD=your_secure_password_here

# Optional (defaults shown)
DB_DATABASE=urban_housing_demand
DB_USER=root

# Backend / Database (used by compose)
DB_ADDRESS=jdbc:mysql://database:3306
MYSQL_ROOT_PASSWORD=your_secure_password_here
MYSQL_DATABASE=urban_housing_demand

# Frontend (dev proxy)
BACKEND_PROXY=http://localhost:8080

# Ingestor (optional - only for external API)
# API_KEY=your_api_key_here
